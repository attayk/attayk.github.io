@article{kremer_electro-gravitational_2019,
	title = {An electro-gravitational induction effect},
	volume = {60},
	issn = {0022-2488},
	html = {https://pubs.aip.org/aip/jmp/article-abstract/60/1/012501/318900/An-electro-gravitational-induction-effect},
	doi = {10.1063/1.5050888},
	abstract = {In this paper, we show that in general relativity the gravitational field induces an electromagnetic field. This is performed by considering the general solution of the homogeneous Maxwell equations in a gravitational field. The solution of these equations involves an ambiguity in the choice of path. This ambiguity is resolved by the derivation and solution of the path of a particle in curved spacetime under the impression of the force of the induced field. This induction effect shows that in the context of general relativity the gravitational and electromagnetic forces are dynamically linked.},
	pages = {012501},
	number = {1},
	journal = {Journal of Mathematical Physics},
	shortjournal = {J. Math. Phys.},
	urldate = {2026-04-25},
	date = {2019-01-23},
	year={2019}
}

